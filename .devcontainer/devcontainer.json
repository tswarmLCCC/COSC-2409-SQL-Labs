{
  "name": "SQL Lab Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "customizations": {
    "vscode": {
      "extensions": [
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "sqltools.connections": [
          {
            "name": "Classroom DB",
            "driver": "PostgreSQL",
            "server": "localhost",
            "port": 5432,
            "database": "classroom",
            "username": "postgres",
            "askForPassword": false,
            "password": "password123"
          }
        ]
      }
    }
  },
  "forwardPorts": [5432],
  "postCreateCommand": "bash .devcontainer/setup.sh"
}
